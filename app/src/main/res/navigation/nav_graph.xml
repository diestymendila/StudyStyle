<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.studystyle.fragments.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_test"
            app:destination="@id/testFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/testFragment"
        android:name="com.example.studystyle.fragments.TestFragment"
        android:label="Tes"
        tools:layout="@layout/fragment_test">
        <action
            android:id="@+id/action_test_to_result"
            app:destination="@id/resultFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/testFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.example.studystyle.fragments.ResultFragment"
        android:label="Hasil"
        tools:layout="@layout/fragment_result">
        <argument
            android:name="result_type"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="visual_score"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="auditory_score"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="kinestetik_score"
            app:argType="integer"
            android:defaultValue="0" />
        <action
            android:id="@+id/action_result_to_test"
            app:destination="@id/testFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/testFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_result_to_home"
            app:destination="@id/homeFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.studystyle.fragments.ProfileFragment"
        android:label="Me"
        tools:layout="@layout/fragment_profile" />

</navigation>