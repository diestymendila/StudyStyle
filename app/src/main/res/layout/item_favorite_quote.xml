<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/background_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Quote mark + delete button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="&#10077;"
                android:textSize="24sp"
                android:textColor="@color/brand_primary"
                android:alpha="0.4" />

            <ImageView
                android:id="@+id/btn_remove_favorite_quote"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_heart_filled"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Hapus dari favorit" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_fav_quote_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?attr/text_primary_color"
            android:lineSpacingMultiplier="1.6"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/divider_color"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_fav_quote_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/brand_primary" />

    </LinearLayout>
</androidx.cardview.widget.CardView>