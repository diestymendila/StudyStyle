<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_header_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasil Tes Kamu"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tv_result_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Pie Chart Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_chart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/background_card"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distribusi Gaya Belajar"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pie_chart"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />

                <!-- Score row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_visual_pct"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/color_visual" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Visual" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_auditory_pct"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/color_auditory" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Auditori" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_kinestetik_pct"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/color_kinestetik" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kinestetik" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Description Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/background_card"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TENTANG KAMU"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_result_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.6" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="14dp" android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KELEBIHAN"
                    android:textSize="11sp"
                    android:textColor="@color/success"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_kelebihan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.7" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KELEMAHAN"
                    android:textSize="11sp"
                    android:textColor="@color/error"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_kekurangan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.7" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Riwayat -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp"
            android:text="Riwayat Tes"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:id="@+id/layout_no_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada riwayat tes"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:nestedScrollingEnabled="false" />

        <!-- Rekomendasi Buku -->
        <TextView
            android:id="@+id/tv_books_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:text="Rekomendasi Buku"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Loading buku -->
        <ProgressBar
            android:id="@+id/progress_books"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:indeterminateTint="@color/brand_primary"
            android:visibility="gone" />

        <!-- Offline books state -->
        <TextView
            android:id="@+id/tv_books_offline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="8dp"
            android:padding="14dp"
            android:text="📡 Rekomendasi buku membutuhkan koneksi internet"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_card_dashed"
            android:gravity="center"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_books"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btn_retake_test"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:text="Ulangi Tes"
            style="@style/ButtonSecondary" />

        <Button
            android:id="@+id/btn_go_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:text="Kembali ke Beranda"
            style="@style/ButtonPrimary" />

    </LinearLayout>
</ScrollView>
