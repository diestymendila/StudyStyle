<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_book"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/card_elevated_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Cover buku -->
        <ImageView
            android:id="@+id/iv_book_cover"
            android:layout_width="60dp"
            android:layout_height="85dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_book_cover_placeholder"
            android:src="@drawable/ic_book_placeholder" />

        <!-- Info buku -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/text_primary_color"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2" />

            <TextView
                android:id="@+id/tv_book_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="12sp"
                android:textColor="@color/brand_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Genre badge + tahun -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_book_genre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_genre_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_book_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/text_secondary_color"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Rating -->
            <TextView
                android:id="@+id/tv_book_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="★ Belum dirating"
                android:textSize="11sp"
                android:textColor="@color/color_kinestetik" />

        </LinearLayout>

        <!-- Favorite icon -->
        <TextView
            android:id="@+id/tv_book_favorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♡"
            android:textSize="20sp"
            android:textColor="?attr/text_secondary_color"
            android:layout_marginStart="8dp"
            android:padding="4dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>