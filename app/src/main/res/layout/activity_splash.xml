<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_primary">

    <!-- Background circle kanan atas -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_circle_overlay"
        android:layout_gravity="top|end"
        android:translationX="60dp"
        android:translationY="-60dp" />

    <!-- Background circle kiri bawah -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_circle_overlay"
        android:layout_gravity="bottom|start"
        android:translationX="-50dp"
        android:translationY="40dp" />

    <!-- Arc gelap bagian bawah -->
    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/bg_arc_bottom"
        android:layout_gravity="bottom" />

    <!-- Konten utama tengah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp">

        <!-- Logo box -->
        <FrameLayout
            android:id="@+id/iv_logo"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/bg_logo_box">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_logo"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- Nama Aplikasi -->
        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="StudyStyle"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <!-- Slogan -->
        <TextView
            android:id="@+id/tv_slogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/slogan"
            android:textColor="#AAFFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.05" />

        <!-- Divider -->
        <View
            android:id="@+id/v_divider"
            android:layout_width="36dp"
            android:layout_height="2dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="#4DFFFFFF" />

        <!-- Tiga ikon gaya belajar -->
        <LinearLayout
            android:id="@+id/ll_styles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Visual -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="20dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_visual" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Visual"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- Auditori -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="20dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_auditory" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Auditori"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- Kinestetik -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_kinesthetic" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kinestetik"
                    android:textColor="#80FFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Versi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="v1.0.0"
        android:textColor="#40FFFFFF"
        android:textSize="9sp" />

</FrameLayout>