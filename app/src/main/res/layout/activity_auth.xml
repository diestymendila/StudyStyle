<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_auth.xml
    Layout ini adalah layar transisi singkat milik AuthActivity.
    AuthActivity langsung meneruskan ke LoginActivity atau MainActivity,
    sehingga layout ini hanya menampilkan splash mini selama proses routing.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_primary">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_logo"
            android:alpha="0.9" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:indeterminateTint="#AAFFFFFF" />

    </LinearLayout>

</FrameLayout>
