<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark theme override -->
    <style name="Theme.StudyStyle" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary_light</item>
        <item name="colorPrimaryDark">@color/brand_primary</item>
        <item name="colorAccent">@color/brand_primary_light</item>
        <item name="colorSurface">@color/dark_card</item>
        <item name="android:colorBackground">@color/dark_surface</item>
        <item name="android:windowBackground">@color/dark_surface</item>
        <item name="android:statusBarColor">@color/dark_surface</item>
        <item name="android:navigationBarColor">@color/dark_card</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="background_primary">@color/dark_surface</item>
        <item name="background_card">@color/dark_card</item>
    </style>

    <style name="InputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/brand_primary_light</item>
        <item name="hintTextColor">@color/brand_primary_light</item>
        <item name="boxBackgroundColor">@color/input_background_dark</item>
    </style>
</resources>